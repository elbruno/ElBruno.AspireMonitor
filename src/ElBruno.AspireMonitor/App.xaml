<Application x:Class="ElBruno.AspireMonitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infrastructure="clr-namespace:ElBruno.AspireMonitor.Infrastructure"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <!-- Converters -->
        <infrastructure:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- Global styles -->
        <SolidColorBrush x:Key="StatusGreen" Color="#4CAF50"/>
        <SolidColorBrush x:Key="StatusYellow" Color="#FFC107"/>
        <SolidColorBrush x:Key="StatusRed" Color="#F44336"/>
        <SolidColorBrush x:Key="StatusGray" Color="#9E9E9E"/>
        
        <Style x:Key="StatusIndicator" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>
        
        <Style x:Key="ClickableUrl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2196F3"/>
            <Setter Property="TextDecorations" Value="Underline"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Application.Resources>
</Application>
