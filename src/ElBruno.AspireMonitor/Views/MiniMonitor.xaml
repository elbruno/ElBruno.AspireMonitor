<Window x:Class="ElBruno.AspireMonitor.Views.MiniMonitor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Mini Monitor"
        Width="350"
        Height="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Border CornerRadius="12"
            Background="#F0F0F0"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            Opacity="0.95"
            Effect="{StaticResource DropShadowEffect}">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="120"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Logo and Title -->
            <StackPanel Grid.Row="0"
                       Orientation="Horizontal"
                       VerticalAlignment="Center"
                       Margin="0,0,0,10">
                <!-- Logo Image -->
                <Image Source="pack://application:,,,/Resources/aspire-logo-128.png"
                      Width="28"
                      Height="28"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Aspire Monitor"
                              FontSize="13"
                              FontWeight="Bold"
                              Foreground="#333333"/>
                    <TextBlock Text="{Binding AppVersion}"
                              FontSize="9"
                              Foreground="#999999"/>
                </StackPanel>
            </StackPanel>

            <!-- Row 1: Working Folder -->
            <StackPanel Grid.Row="1"
                       Orientation="Vertical"
                       Margin="0,0,0,10">
                <TextBlock Text="Working Folder:"
                          FontSize="9"
                          FontWeight="SemiBold"
                          Foreground="#666666"
                          Margin="0,0,0,2"/>
                <TextBlock Text="{Binding WorkingFolder}"
                          FontSize="9"
                          Foreground="#333333"
                          TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Row 2: Status Info -->
            <StackPanel Grid.Row="2"
                       Orientation="Vertical"
                       Margin="0,0,0,10">
                <TextBlock Text="{Binding ResourceCount}"
                          FontSize="11"
                          FontWeight="SemiBold"
                          Foreground="#333333"
                          Margin="0,0,0,5"/>
                <TextBlock Text="{Binding DetailsSummary}"
                          FontSize="10"
                          Foreground="#666666"
                          TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Row 3: Log Viewer -->
            <Border Grid.Row="3"
                    Background="#1E1E1E"
                    CornerRadius="4"
                    BorderBrush="#333333"
                    BorderThickness="1"
                    Margin="0,10,0,10">
                <ListBox ItemsSource="{Binding LogLines}"
                        Background="Transparent"
                        Foreground="#E0E0E0"
                        BorderThickness="0"
                        Padding="8,6"
                        FontFamily="Courier New"
                        FontSize="9"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0,1"/>
                            <Setter Property="Margin" Value="0,0,0,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.Resources>
                </ListBox>
            </Border>

            <!-- Row 4: Action Buttons -->
            <Grid Grid.Row="4"
                 Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Content="▶ Start"
                       Grid.Column="0"
                       Height="28"
                       Padding="0"
                       FontSize="10"
                       Margin="0,0,5,0"
                       Click="Start_Click"
                       Background="#4CAF50"
                       Foreground="White"/>
                
                <Button Content="⏹ Stop"
                       Grid.Column="1"
                       Height="28"
                       Padding="0"
                       FontSize="10"
                       Margin="0,0,5,0"
                       Click="Stop_Click"
                       Background="#F44336"
                       Foreground="White"/>
                
                <Button Content="Details"
                       Grid.Column="2"
                       Height="28"
                       Padding="0"
                       FontSize="10"
                       Margin="0,0,5,0"
                       Click="OpenDetails_Click"/>
                
                <Button Content="Close"
                       Grid.Column="3"
                       Height="28"
                       Padding="0"
                       FontSize="10"
                       Click="Close_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
