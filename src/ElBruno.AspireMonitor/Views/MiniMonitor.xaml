<Window x:Class="ElBruno.AspireMonitor.Views.MiniMonitor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Mini Monitor"
        Width="280"
        Height="140"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Border CornerRadius="12"
            Background="#F0F0F0"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            Opacity="0.95"
            Effect="{StaticResource DropShadowEffect}">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top: Status Emoji and Title -->
            <StackPanel Grid.Row="0"
                       Orientation="Horizontal"
                       VerticalAlignment="Center"
                       Margin="0,0,0,10">
                <TextBlock Text="{Binding StatusEmoji}"
                          FontSize="28"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Aspire Monitor"
                              FontSize="13"
                              FontWeight="Bold"
                              Foreground="#333333"/>
                    <TextBlock Text="{Binding AppVersion}"
                              FontSize="9"
                              Foreground="#999999"/>
                </StackPanel>
            </StackPanel>

            <!-- Middle: Status Info -->
            <StackPanel Grid.Row="1"
                       Orientation="Vertical"
                       VerticalAlignment="Center">
                <TextBlock Text="{Binding ResourceCount}"
                          FontSize="11"
                          FontWeight="SemiBold"
                          Foreground="#333333"
                          Margin="0,0,0,5"/>
                <TextBlock Text="{Binding DetailsSummary}"
                          FontSize="10"
                          Foreground="#666666"
                          TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Bottom: Action Links -->
            <StackPanel Grid.Row="2"
                       Orientation="Horizontal"
                       HorizontalAlignment="Right"
                       Margin="0,10,0,0">
                <Button Content="Details"
                       Width="60"
                       Height="24"
                       Padding="0"
                       FontSize="10"
                       Margin="0,0,5,0"
                       Click="OpenDetails_Click"/>
                <Button Content="Close"
                       Width="50"
                       Height="24"
                       Padding="0"
                       FontSize="10"
                       Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
