<Window x:Class="ElBruno.AspireMonitor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Aspire Monitor" 
        Height="500" 
        Width="800"
        MinHeight="400"
        MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Visibility="Hidden"
        ShowInTaskbar="False"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Version & Title Bar -->
        <TextBlock Grid.Row="0"
                   Text="{Binding AppVersionTitle}"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="#333333"
                   Margin="0,0,0,10"/>

        <!-- Aspire Logo & Title Bar -->
        <Grid Grid.Row="0"
              Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Logo Image -->
            <Image Grid.Column="0"
                   Source="pack://application:,,,/Resources/aspire-logo.svg"
                   Width="32"
                   Height="32"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"/>

            <!-- Title -->
            <TextBlock Grid.Column="1"
                       Text="{Binding AppVersionTitle}"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="#333333"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Error Banner (visible when not connected) -->
        <Border Grid.Row="1" 
                Background="#FFF4E5" 
                BorderBrush="#FFB74D" 
                BorderThickness="1" 
                Padding="10"
                Margin="0,0,0,10"
                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" 
                           FontSize="16" 
                           Margin="0,0,10,0"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ConnectionStatus}" 
                           FontSize="12" 
                           FontWeight="SemiBold"
                           Foreground="#E65100"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Top Section: Host URL and Status -->
        <Border Grid.Row="1" 
                BorderBrush="#CCCCCC" 
                BorderThickness="0,0,0,1" 
                Padding="10"
                Margin="0,0,0,10"
                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status Indicator -->
                <Ellipse Grid.Row="0" 
                         Grid.Column="0"
                         Style="{StaticResource StatusIndicator}"
                         Fill="{Binding OverallStatusColor}"
                         VerticalAlignment="Center"/>

                <!-- Host URL (Clickable) -->
                <TextBlock Grid.Row="0" 
                           Grid.Column="1"
                           Style="{StaticResource ClickableUrl}"
                           Text="{Binding HostUrl}"
                           FontSize="14"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="5,0"
                           MouseLeftButtonDown="HostUrl_Click"/>

                <!-- Connection Status -->
                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Text="{Binding ConnectionStatus}"
                           FontSize="12"
                           Foreground="{Binding OverallStatusColor}"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>

                <!-- Start Button -->
                <Button Grid.Row="0"
                        Grid.Column="3"
                        Content="▶ Start"
                        Width="70"
                        Height="24"
                        Padding="5,2"
                        Margin="10,0,5,0"
                        Command="{Binding StartAspireCommand}"
                        VerticalAlignment="Center"
                        FontSize="11"/>

                <!-- Stop Button -->
                <Button Grid.Row="0"
                        Grid.Column="4"
                        Content="⏹ Stop"
                        Width="70"
                        Height="24"
                        Padding="5,2"
                        Margin="0,0,0,0"
                        Command="{Binding StopAspireCommand}"
                        VerticalAlignment="Center"
                        FontSize="11"/>

                <!-- Last Updated -->
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Grid.ColumnSpan="4"
                           Text="{Binding LastUpdatedText}"
                           FontSize="10"
                           Foreground="#666666"
                           Margin="5,5,0,0"/>

                <!-- Project Folder Row -->
                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Grid.ColumnSpan="5"
                           FontSize="10"
                           Foreground="#666666"
                           Margin="5,8,0,0">
                    <Run Text="📁 Working Folder: "/>
                    <Run Text="{Binding ProjectFolder, Mode=OneWay}"
                         FontWeight="Bold"
                         Foreground="#333333"/>
                </TextBlock>

                <!-- Command Status -->
                <TextBlock Grid.Row="2"
                           Grid.Column="3"
                           Grid.ColumnSpan="2"
                           Text="{Binding CommandStatus}"
                           FontSize="11"
                           Foreground="#D32F2F"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,8,0,0"/>
            </Grid>
        </Border>

        <!-- Middle Section: Resource List -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Resources}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#EEEEEE" 
                                BorderThickness="0,0,0,1" 
                                Padding="10,8"
                                Margin="0,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Status Indicator -->
                                <Ellipse Grid.Column="0"
                                         Style="{StaticResource StatusIndicator}"
                                         Fill="{Binding StatusColor}"
                                         VerticalAlignment="Center"/>

                                <!-- Resource Name -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="5,0,10,0"/>

                                <!-- CPU Usage -->
                                <StackPanel Grid.Column="2" 
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,0,10,0">
                                    <TextBlock Text="CPU: " 
                                               FontSize="11" 
                                               Foreground="#666666"/>
                                    <TextBlock Text="{Binding CpuUsageText}" 
                                               FontSize="11" 
                                               FontWeight="Bold"/>
                                </StackPanel>

                                <!-- Memory Usage -->
                                <StackPanel Grid.Column="3" 
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,0,10,0">
                                    <TextBlock Text="MEM: " 
                                               FontSize="11" 
                                               Foreground="#666666"/>
                                    <TextBlock Text="{Binding MemoryUsageText}" 
                                               FontSize="11" 
                                               FontWeight="Bold"/>
                                </StackPanel>

                                <!-- URL (Clickable if available) -->
                                <TextBlock Grid.Column="4"
                                           Style="{StaticResource ClickableUrl}"
                                           Text="{Binding UrlDisplay}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           MouseLeftButtonDown="ResourceUrl_Click"
                                           Visibility="{Binding HasUrl, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Bottom Section: Control Buttons -->
        <Border Grid.Row="3" 
                BorderBrush="#CCCCCC" 
                BorderThickness="0,1,0,0" 
                Padding="10"
                Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <Button Content="Refresh" 
                        Width="80" 
                        Height="30"
                        Margin="0,0,10,0"
                        Click="Refresh_Click"/>
                <Button Content="Mini Monitor" 
                        Width="100" 
                        Height="30"
                        Margin="0,0,10,0"
                        Click="MiniMonitor_Click"/>
                <Button Content="Close" 
                        Width="80" 
                        Height="30"
                        Click="Close_Click"/>
            </StackPanel>
        </Border>

        <!-- Version Footer -->
        <TextBlock Grid.Row="4"
                   Text="{Binding AppVersion}"
                   FontSize="9"
                   Foreground="#999999"
                   HorizontalAlignment="Right"
                   Margin="0,5,0,0"/>
    </Grid>
</Window>
