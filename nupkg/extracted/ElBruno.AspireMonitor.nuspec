<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>ElBruno.AspireMonitor</id>
    <version>1.0.0</version>
    <title>ElBruno.AspireMonitor</title>
    <authors>Bruno Capuano</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>aspire-monitor-icon-128.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/elbruno/ElBruno.AspireMonitor</projectUrl>
    <description>Real-time Windows system tray monitor for .NET Aspire distributed applications. Monitor CPU, memory, and health status of your Aspire resources with color-coded indicators and clickable URLs.</description>
    <releaseNotes>https://github.com/elbruno/ElBruno.AspireMonitor/releases/tag/v1.0.0</releaseNotes>
    <copyright>Copyright (c) 2026 Bruno Capuano</copyright>
    <tags>aspire monitoring dotnet system-tray windows devtools aspire-monitor real-time wpf</tags>
    <repository type="git" url="https://github.com/elbruno/ElBruno.AspireMonitor" commit="79ef8a3f460dbee6aef36cdada8cb9b369bd6e37" />
    <dependencies>
      <group targetFramework="net10.0-windows7.0">
        <dependency id="Microsoft.Extensions.Http" version="9.0.0" exclude="Build,Analyzers" />
        <dependency id="Polly" version="8.5.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
    <frameworkReferences>
      <group targetFramework="net10.0-windows7.0">
        <frameworkReference name="Microsoft.WindowsDesktop.App" />
      </group>
    </frameworkReferences>
  </metadata>
</package>